# 🌐 General Configuration
NODE_ENV=development
HTTP_PORT=3000

# 🧠 Core Model Configuration
MODEL_PROVIDER=openrouter
MODEL_NAME=google/gemini-2.0-pro-exp-02-05:free
MODEL_API_KEY=your_openrouter_api_key_here
MAX_TOKENS=4000
TEMPERATURE=0.7

# 📱 Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWLIST_USER_ID=your_telegram_user_id_here

# 🎤 Voice & TTS Configuration
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TRANSCRIPTION_MOCK_MODE=true
TTS_MOCK_MODE=true

# 🧠 Vector DB / Memory Configuration
VECTOR_DB_MOCK_MODE=true
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your_qdrant_api_key_here

# 📞 Vapi Configuration (WEBHOOK)
VAPI_PRIVATE_KEY=your_vapi_private_key_here
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# 💓 System Configuration
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_MS=300000
