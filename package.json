{
  "name": "agent-claw",
  "version": "1.0.0",
  "description": "Agent Claw — Telegram AI Assistant with voice, memory, and MCP integrations",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "dev": "npx tsx watch src/index.ts",
    "build": "tsc",
    "test": "npx tsx tests/self-test.ts",
    "test:memory": "npx tsx tests/self-test.ts",
    "lint": "npx eslint src/ --ext .ts",
    "format": "npx prettier --write src/",
    "format:check": "npx prettier --check src/",
    "typecheck": "tsc --noEmit",
    "swarm:spawn": "powershell -File ./.clawdbot/spawn-agent.ps1",
    "swarm:pulse": "powershell -File ./.clawdbot/check-agents.ps1",
    "swarm:help": "cat docs/SWARM.md"
  },
  "keywords": [
    "telegram",
    "bot",
    "ai",
    "assistant",
    "openrouter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.36.0",
    "@grammyjs/files": "^1.1.1",
    "@steipete/summarize": "^0.11.1",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "grammy": "^1.35.0",
    "mcporter": "^0.7.3",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.85.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "turndown": "^7.2.2",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "^3.2.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.5",
    "@types/node-cron": "^3.0.11",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.21.0",
    "prettier": "^3.5.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
